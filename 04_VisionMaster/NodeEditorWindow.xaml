<Window x:Class="VisionMaster.NodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="520"
        Height="360"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI"
        >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="{Binding Description}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding Label}" />

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Background="#1F2228"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsText, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBox Background="#1F2228"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsFilePath, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button Grid.Column="1"
                                            Width="76"
                                            Margin="10,0,0,0"
                                            Command="{Binding BrowseCommand}"
                                            Content="浏览"
                                            Visibility="{Binding IsFilePath, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <ComboBox Background="#1F2228"
                                              BorderBrush="{StaticResource BorderBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding Options}"
                                              SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Value"
                                              Visibility="{Binding IsComboBox, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,10,0"
                    Click="OkButton_OnClick"
                    Content="确定" />
            <Button Width="88"
                    Click="CancelButton_OnClick"
                    Content="取消" />
        </StackPanel>
    </Grid>
</Window>
