<Window x:Class="VisionMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="VisionMaster Workbench"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#2F323A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="ToolTileStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#2E323A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="NodeThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PortThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="{Binding Diameter}" />
            <Setter Property="Height" Value="{Binding Diameter}" />
            <Setter Property="Cursor" Value="Cross" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="White"
                                BorderThickness="1"
                                CornerRadius="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectionHandleThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Cursor" Value="Cross" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Ellipse Fill="#1C1F25"
                                 Stroke="{StaticResource TextPrimaryBrush}"
                                 StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#111215"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="82" />
                <RowDefinition Height="*" />
                <RowDefinition Height="26" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource ChromeBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="18,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,-2,6,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="V" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <Run FontStyle="Italic"
                                 FontWeight="Bold"
                                 Text="vision" />
                            <LineBreak />
                            <Run FontStyle="Italic"
                                 Text="master" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="文件" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="设置" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="工具" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="系统" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="帮助" Style="{StaticResource MenuButtonStyle}" />
                    </StackPanel>

                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="126" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,16,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="&#xE77B;" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding CurrentUserName}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Click="MinimizeButton_OnClick"
                                    Content="&#xE921;"
                                    Style="{StaticResource WindowButtonStyle}" />
                            <Button Click="MaximizeButton_OnClick"
                                    Content="&#xE922;"
                                    Style="{StaticResource WindowButtonStyle}" />
                            <Button Click="CloseButton_OnClick"
                                    Content="&#xE8BB;"
                                    Foreground="White"
                                    Background="#C42B1C"
                                    Style="{StaticResource WindowButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <ItemsControl Grid.Row="1"
                              Margin="18,0,0,0"
                              ItemsSource="{Binding ToolbarActions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ExecuteToolbarActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ToolbarButtonStyle}">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Text="{Binding Glyph}" />
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="11"
                                               Text="{Binding Name}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="410" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="模块库" />

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource CategoryButtonStyle}">
                                        <TextBlock Text="{Binding Name}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ScrollViewer Grid.Row="4"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding VisibleTools}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.AddToolToFlowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolTileStyle}">
                                            <StackPanel>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="24"
                                                           Text="{Binding Glyph}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding Name}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Background="#202228">
                    <Canvas x:Name="FlowCanvas"
                            Focusable="True"
                            Background="{StaticResource CanvasGridBrush}"
                            ClipToBounds="True"
                            PreviewMouseLeftButtonDown="FlowCanvas_OnPreviewMouseLeftButtonDown">
                        <ItemsControl ItemsSource="{Binding FlowEditor.Connections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Path Data="{Binding Geometry}"
                                              Stroke="{Binding Stroke}"
                                              StrokeThickness="{Binding StrokeThickness}" />
                                        <Path Data="{Binding Geometry}"
                                              Stroke="Transparent"
                                              StrokeThickness="14"
                                              MouseLeftButtonDown="ConnectionHitPath_OnMouseLeftButtonDown" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Path Data="{Binding FlowEditor.DraftConnection.Geometry}"
                              Stroke="#FFB36A"
                              StrokeThickness="2"
                              StrokeDashArray="3,2"
                              Visibility="{Binding FlowEditor.DraftConnection.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <ItemsControl ItemsSource="{Binding FlowEditor.Nodes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding Width}"
                                          Height="{Binding Height}"
                                          MouseLeftButtonDown="NodeCard_OnPreviewMouseLeftButtonDown">
                                        <Border Background="#F5F5F5"
                                                BorderBrush="{Binding AccentBrush}"
                                                CornerRadius="18">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="16"
                                                        Height="16"
                                                        Margin="8,0,0,0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="White"
                                                        BorderBrush="{Binding AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Foreground="{Binding AccentBrush}"
                                                               Text="{Binding Glyph}" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1E2127"
                                                               Text="{Binding Title}" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontSize="9"
                                                               Foreground="#6B7280"
                                                               Text="{Binding SecondaryText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <primitives:Thumb DragStarted="NodeThumb_OnDragStarted"
                                                          DragDelta="NodeThumb_OnDragDelta"
                                                          PreviewMouseLeftButtonDown="NodeCard_OnPreviewMouseLeftButtonDown"
                                                          Style="{StaticResource NodeThumbStyle}" />

                                        <ItemsControl ItemsSource="{Binding OutputPorts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                                    <Setter Property="Visibility" Value="{Binding IsVisibleHandle, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <primitives:Thumb DragCompleted="PortThumb_OnDragCompleted"
                                                                      DragDelta="PortThumb_OnDragDelta"
                                                                      DragStarted="PortThumb_OnDragStarted"
                                                                      Style="{StaticResource PortThumbStyle}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <primitives:Thumb Canvas.Left="{Binding FlowEditor.SelectedConnection.StartHandleLeft, FallbackValue=-100}"
                                          Canvas.Top="{Binding FlowEditor.SelectedConnection.StartHandleTop, FallbackValue=-100}"
                                          DragCompleted="ConnectionHandleThumb_OnDragCompleted"
                                          DragDelta="ConnectionHandleThumb_OnDragDelta"
                                          DragStarted="ConnectionHandleThumb_OnDragStarted"
                                          Style="{StaticResource ConnectionHandleThumbStyle}"
                                          Tag="Source"
                                          Visibility="{Binding FlowEditor.HasSelectedConnection, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <primitives:Thumb Canvas.Left="{Binding FlowEditor.SelectedConnection.EndHandleLeft, FallbackValue=-100}"
                                          Canvas.Top="{Binding FlowEditor.SelectedConnection.EndHandleTop, FallbackValue=-100}"
                                          DragCompleted="ConnectionHandleThumb_OnDragCompleted"
                                          DragDelta="ConnectionHandleThumb_OnDragDelta"
                                          DragStarted="ConnectionHandleThumb_OnDragStarted"
                                          Style="{StaticResource ConnectionHandleThumbStyle}"
                                          Tag="Target"
                                          Visibility="{Binding FlowEditor.HasSelectedConnection, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Canvas>
                </Grid>

                <Grid Grid.Column="2"
                      Background="{StaticResource PanelAltBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.2*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Margin="12,12,12,6"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid Background="{StaticResource CheckerBrush}">
                            <Border Width="260"
                                    Padding="18,16"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#1F2126"
                                    BorderBrush="#3B4049"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="流程图像预览" />
                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding PreviewSummary}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="12,6,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="3">
                            <Border Margin="0,0,8,0"
                                    Padding="12"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="模块数" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding FlowNodeCount}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,8,0"
                                    Padding="12"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="连线数" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding FlowConnectionCount}" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="最近动作" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding LastAction}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Padding="12"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="节点已缩小为紧凑样式，四边都可发起连线；拖到目标节点本体即可自动吸附完成连接。图像源支持双击打开动态配置。"
                                       TextWrapping="Wrap" />
                        </Border>

                        <DataGrid Grid.Row="4"
                                  AutoGenerateColumns="False"
                                  Background="{StaticResource PanelBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding HistoryRecords}"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="100"
                                                    Binding="{Binding Sequence}"
                                                    Header="执行序号" />
                                <DataGridTextColumn Width="140"
                                                    Binding="{Binding Time}"
                                                    Header="时间" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding Module}"
                                                    Header="模块数据" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="2"
                  Background="#1E2024">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
                <TextBlock Grid.Column="1"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding FlowDurationText}" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding CanvasZoomText}" />
            </Grid>
        </Grid>
    </Border>
</Window>
