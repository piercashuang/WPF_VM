<Application x:Class="VisionMaster.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1B1C20" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#232428" />
        <SolidColorBrush x:Key="PanelBrush" Color="#25272D" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#2B2E36" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#31343C" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3B3F47" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A6ADBB" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF8A24" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#4FC975" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F55E5E" />

        <DrawingBrush x:Key="CanvasGridBrush"
                      TileMode="Tile"
                      Viewport="0,0,20,20"
                      ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#202228">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,20,20" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#2C3038">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,1,20" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#2C3038">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,20,1" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,18,18"
                      ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#2C3037">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,18,18" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#353944">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,9,9" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#353944">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="9,9,9,9" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Application.Resources>
</Application>
