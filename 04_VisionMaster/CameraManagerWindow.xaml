<Window x:Class="VisionMaster.CameraManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="相机管理"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal">
                    <Button Width="88"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding ScanCommand}"
                            Content="扫描相机" />
                    <Button Width="72"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding OpenCommand}"
                            Content="连接" />
                    <Button Width="72"
                            Height="32"
                            Command="{Binding CloseCommand}"
                            Content="关闭" />
                </StackPanel>

                <ListBox Margin="0,14,0,0"
                         ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding SelectedDevice}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#2E323A"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding TransportLayer}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding SerialNumber}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Width="96"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding StartGrabCommand}"
                            Content="开始采集" />
                    <Button Grid.Column="1"
                            Width="96"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding StopGrabCommand}"
                            Content="停止采集" />
                    <Button Grid.Column="2"
                            Width="96"
                            Height="34"
                            Margin="0,0,18,0"
                            Command="{Binding TriggerCommand}"
                            Content="软触发" />

                    <CheckBox Grid.Column="3"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              IsChecked="{Binding UseSoftwareTrigger}"
                              Content="启用软触发模式" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Background="{StaticResource CheckerBrush}">
                    <Image Margin="12"
                           Stretch="Uniform"
                           Source="{Binding PreviewImage}" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
