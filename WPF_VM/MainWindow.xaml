<Window x:Class="WPF_VM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="VisionMaster Workbench"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F323A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="52" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#2F323A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3F48" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#272B33" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E323A" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolTileStyle" TargetType="Button">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="86" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F333B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="#2B2E36" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#343842" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#363A43" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PortThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="{Binding Diameter}" />
            <Setter Property="Height" Value="{Binding Diameter}" />
            <Setter Property="Cursor" Value="Cross" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid>
                            <Ellipse Fill="#1C1F25"
                                     Stroke="{StaticResource AccentBrush}"
                                     StrokeThickness="2" />
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="{StaticResource AccentBrush}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectionHandleThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Cursor" Value="Cross" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Ellipse Fill="#1C1F25"
                                 Stroke="{StaticResource TextPrimaryBrush}"
                                 StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#111215"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="82" />
                <RowDefinition Height="*" />
                <RowDefinition Height="26" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource ChromeBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="18,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,-2,6,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="V" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <Run FontStyle="Italic"
                                 FontWeight="Bold"
                                 Text="vision" />
                            <LineBreak />
                            <Run FontStyle="Italic"
                                 Text="master" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="文件" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="设置" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="工具" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="系统" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="帮助" Style="{StaticResource MenuButtonStyle}" />
                    </StackPanel>

                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="126" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,16,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="&#xE77B;" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding CurrentUserName}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Click="MinimizeButton_OnClick"
                                    Content="&#xE921;"
                                    Style="{StaticResource WindowButtonStyle}" />
                            <Button Click="MaximizeButton_OnClick"
                                    Content="&#xE922;"
                                    Style="{StaticResource WindowButtonStyle}" />
                            <Button Click="CloseButton_OnClick"
                                    Content="&#xE8BB;"
                                    Style="{StaticResource CloseWindowButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0"
                                  Margin="18,0,0,0"
                                  ItemsSource="{Binding ToolbarActions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ExecuteToolbarActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ToolbarButtonStyle}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18"
                                                   Text="{Binding Glyph}" />
                                        <TextBlock Margin="0,3,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="11"
                                                   Text="{Binding Name}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Column="1"
                            Margin="0,8,16,8"
                            Background="#2E323A"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE7C3;" />
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="运行模式" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#23252B"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="230" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="18,18,12,8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding SelectedCategory.Name}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="双击工具可快速加入当前流程，当前为视觉流程编辑演示界面。" />

                            <ItemsControl Margin="0,18,0,0"
                                          ItemsSource="{Binding VisibleTools}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.AddToolToFlowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolTileStyle}">
                                            <StackPanel>
                                                <Border Width="42"
                                                        Height="42"
                                                        HorizontalAlignment="Center"
                                                        Background="#333843"
                                                        CornerRadius="10">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="20"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Text="{Binding Glyph}" />
                                                </Border>
                                                <TextBlock Margin="0,8,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="{Binding Name}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,8,0,0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="15"
                                                           Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="&#xE76C;" />
                                            </Grid>
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource CategoryButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#2D313A" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="BorderThickness" Value="1,0,0,0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Background="{StaticResource WindowBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#2A2D34"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="14,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Margin="0,0,10,0"
                                        Padding="12,8"
                                        Background="#343944"
                                        CornerRadius="8,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="&#xE7F8;" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding CurrentPipelineName}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding PreviewSummary}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Margin="0,0,12,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           Text="&#xE721;" />
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           Text="&#xE8A5;" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Canvas x:Name="FlowCanvas"
                                Background="{StaticResource CanvasGridBrush}"
                                ClipToBounds="True"
                                Focusable="True"
                                PreviewMouseLeftButtonDown="FlowCanvas_OnPreviewMouseLeftButtonDown">
                            <ItemsControl ItemsSource="{Binding FlowEditor.Connections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0" />
                                        <Setter Property="Canvas.Top" Value="0" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Path Data="{Binding Geometry}"
                                                  MouseLeftButtonDown="ConnectionHitPath_OnMouseLeftButtonDown"
                                                  Stroke="Transparent"
                                                  StrokeThickness="16"
                                                  StrokeEndLineCap="Round"
                                                  StrokeStartLineCap="Round" />
                                            <Path Data="{Binding Geometry}"
                                                  Stroke="{Binding Stroke}"
                                                  StrokeThickness="{Binding StrokeThickness}"
                                                  StrokeEndLineCap="Round"
                                                  StrokeStartLineCap="Round" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Path Data="{Binding FlowEditor.DraftConnection.Geometry}"
                                  Stroke="{StaticResource AccentBrush}"
                                  StrokeDashArray="4,4"
                                  StrokeThickness="3"
                                  Visibility="{Binding FlowEditor.DraftConnection.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding FlowEditor.Nodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}"
                                              Height="{Binding Height}">
                                            <primitives:Thumb Cursor="SizeAll"
                                                              DragDelta="NodeThumb_OnDragDelta"
                                                              DragStarted="NodeThumb_OnDragStarted">
                                                <primitives:Thumb.Template>
                                                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                                                        <Border Background="#292D35"
                                                                BorderBrush="#3C414B"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="#3C414B" />
                                                                    <Setter Property="Background" Value="#292D35" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                            <Setter Property="Background" Value="#2F333C" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid Margin="14,12">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="24" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Ellipse Width="10"
                                                                             Height="10"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding AccentBrush}" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="8,0,0,0"
                                                                               FontSize="14"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               Text="{Binding Title}" />
                                                                    <Border Grid.Column="2"
                                                                            Padding="8,3"
                                                                            Background="#343944"
                                                                            CornerRadius="10">
                                                                        <TextBlock FontSize="11"
                                                                                   Foreground="{Binding AccentBrush}"
                                                                                   Text="{Binding Tag}" />
                                                                    </Border>
                                                                </Grid>

                                                                <TextBlock Grid.Row="1"
                                                                           Margin="0,10,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Text="{Binding Description}"
                                                                           TextWrapping="Wrap" />

                                                                <Grid Grid.Row="2"
                                                                      Margin="0,8,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               Text="{Binding Glyph}" />
                                                                    <TextBlock Grid.Column="2"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               Text="{Binding NodeKind}" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </primitives:Thumb.Template>
                                            </primitives:Thumb>

                                            <ItemsControl ItemsSource="{Binding InputPorts}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <primitives:Thumb DragCompleted="PortThumb_OnDragCompleted"
                                                                          DragDelta="PortThumb_OnDragDelta"
                                                                          DragStarted="PortThumb_OnDragStarted"
                                                                          Style="{StaticResource PortThumbStyle}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding OutputPorts}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <primitives:Thumb DragCompleted="PortThumb_OnDragCompleted"
                                                                          DragDelta="PortThumb_OnDragDelta"
                                                                          DragStarted="PortThumb_OnDragStarted"
                                                                          Style="{StaticResource PortThumbStyle}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <primitives:Thumb Canvas.Left="{Binding FlowEditor.SelectedConnection.StartHandleLeft, FallbackValue=-100}"
                                              Canvas.Top="{Binding FlowEditor.SelectedConnection.StartHandleTop, FallbackValue=-100}"
                                              DragCompleted="ConnectionHandleThumb_OnDragCompleted"
                                              DragDelta="ConnectionHandleThumb_OnDragDelta"
                                              DragStarted="ConnectionHandleThumb_OnDragStarted"
                                              Style="{StaticResource ConnectionHandleThumbStyle}"
                                              Tag="Source"
                                              Visibility="{Binding FlowEditor.HasSelectedConnection, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <primitives:Thumb Canvas.Left="{Binding FlowEditor.SelectedConnection.EndHandleLeft, FallbackValue=-100}"
                                              Canvas.Top="{Binding FlowEditor.SelectedConnection.EndHandleTop, FallbackValue=-100}"
                                              DragCompleted="ConnectionHandleThumb_OnDragCompleted"
                                              DragDelta="ConnectionHandleThumb_OnDragDelta"
                                              DragStarted="ConnectionHandleThumb_OnDragStarted"
                                              Style="{StaticResource ConnectionHandleThumbStyle}"
                                              Tag="Target"
                                              Visibility="{Binding FlowEditor.HasSelectedConnection, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <Border Canvas.Bottom="18"
                                    Canvas.Right="18"
                                    Width="190"
                                    Height="126"
                                    Background="#1F2126"
                                    BorderBrush="#3B4049"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid Margin="10">
                                    <Border Background="#262A31"
                                            BorderBrush="#444A54"
                                            BorderThickness="1" />
                                    <Rectangle Margin="18,22,54,40"
                                               Stroke="{StaticResource AccentBrush}"
                                               StrokeThickness="1.5" />
                                </Grid>
                            </Border>
                        </Canvas>

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="16"
                                Padding="10,6"
                                Background="#262A31"
                                BorderBrush="#3A3F48"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding FlowDurationText}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="2"
                      Background="#262930">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.15*" />
                        <RowDefinition Height="0.85*" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="0"
                                Background="#262930"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource TabItemStyle}">
                        <TabItem Header="流程图像">
                            <Grid Background="#2B2E36">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="10,8"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <ComboBox Width="180"
                                                  Background="#1E2025"
                                                  BorderBrush="#3A3F48"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="流程输出" />
                                            <ComboBoxItem Content="图像源" />
                                            <ComboBoxItem Content="模板匹配" />
                                        </ComboBox>

                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Margin="0,0,8,0"
                                                    Width="34"
                                                    Height="28"
                                                    Background="#2F333B"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="&#xE8A7;" />
                                            </Button>
                                            <Button Margin="0,0,8,0"
                                                    Width="34"
                                                    Height="28"
                                                    Background="#2F333B"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="&#xE71F;" />
                                            </Button>
                                            <Button Width="34"
                                                    Height="28"
                                                    Background="#2F333B"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="&#xE740;" />
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <Grid Grid.Row="1"
                                      Background="{StaticResource CheckerBrush}">
                                    <Border Width="260"
                                            Padding="18,16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#1F2126"
                                            BorderBrush="#3B4049"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="流程图像预览" />
                                            <TextBlock Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding PreviewSummary}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="模块结果">
                            <Grid Margin="14"
                                  Background="#2B2E36">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="当前流程概览" />

                                <UniformGrid Grid.Row="1"
                                             Margin="0,14,0,14"
                                             Columns="3">
                                    <Border Margin="0,0,10,0"
                                            Padding="12"
                                            Background="#31353F"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="模块数量" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding FlowNodeCount}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,10,0"
                                            Padding="12"
                                            Background="#31353F"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="连线数量" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding FlowConnectionCount}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="12"
                                            Background="#31353F"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="最近动作" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding LastAction}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Grid.Row="2"
                                        Padding="16"
                                        Background="#24272E"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="当前能力" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="1. 标准 WindowChrome 窗口拖动。&#x0a;2. 节点拖动、端口建线、连线重连与删除。&#x0a;3. 受控线程池流程执行服务。&#x0a;4. README 技术选型与扩展点说明。"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <TabControl Grid.Row="1"
                                Background="#262930"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource TabItemStyle}">
                        <TabItem Header="历史结果">
                            <Grid Background="#2B2E36">
                                <DataGrid Margin="12"
                                          AutoGenerateColumns="False"
                                          Background="#2A2D34"
                                          BorderBrush="{StaticResource BorderBrush}"
                                          BorderThickness="1"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding HistoryRecords}"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="100"
                                                            Binding="{Binding Sequence}"
                                                            Header="执行序号" />
                                        <DataGridTextColumn Width="140"
                                                            Binding="{Binding Time}"
                                                            Header="时间" />
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding Module}"
                                                            Header="模块数据" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="帮助">
                            <Border Padding="18"
                                    Background="#2B2E36">
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="当前版本已经完成 VisionMaster 风格工作台的核心交互骨架。后续可以继续接入海康相机采集、参数面板、流程持久化和真实算法执行器。"
                                           TextWrapping="Wrap" />
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>

            <Grid Grid.Row="2"
                  Background="#1E2024">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
                <TextBlock Grid.Column="1"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding FlowDurationText}" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding CanvasZoomText}" />
            </Grid>
        </Grid>
    </Border>
</Window>
